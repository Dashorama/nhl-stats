# NHL Stats Environment Configuration
# Copy to .env and customize

# Database (SQLite default, PostgreSQL for production)
NHL_STATS_DB=sqlite:///data/nhl.db
# NHL_STATS_DB=postgresql://user:pass@localhost:5432/nhl

# Logging
NHL_STATS_LOG_LEVEL=INFO

# Cache directory (for HTTP response caching)
NHL_STATS_CACHE_DIR=./cache

# Optional: Discord webhook for notifications
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Yahoo Fantasy Sports API (create app at https://developer.yahoo.com/apps/create/)
# YAHOO_CONSUMER_KEY=your_consumer_key_here
# YAHOO_CONSUMER_SECRET=
# YAHOO_LEAGUE_ID=your_league_id_here
